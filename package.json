{
  "name": "shop502-tui",
  "version": "0.1.0",
  "description": "POC de TUI para el manejo del carrito de usuarios anónimos - Shop 502",
  "type": "module",
  "bin": {
    "shop502-tui": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
